<Window x:Class="SecurityCheckGui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SecurityCheckGui"
        mc:Ignorable="d"
        Title="OPC UA Server Security Check" Height="800" Width="1000"
        Background="#F5F5F5" FontFamily="Segoe UI" FontSize="11"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">

    <Window.Resources>
        <local:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="#2C3E50" Margin="0">
            <StackPanel Margin="20">
                <TextBlock Text="OPC UA Server Security Check" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Überprüfung der Sicherheitseinstellungen eines OPC UA Servers" Foreground="#BDC3C7" Margin="0,5,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1">
            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="250"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Input Section -->
                <Border Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,20" Background="White" BorderBrush="#D0D0D0" BorderThickness="1">
                    <StackPanel Margin="15">
                        <TextBlock Text="Server URL:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Height="35" Padding="10" Margin="0,0,0,10" 
                                 Text="{Binding ServerUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 Background="#ECEFF1" BorderBrush="#BDC3C7" BorderThickness="1"/>

                        <CheckBox Content="Auto Accept Untrusted Certificates" Margin="0,0,0,10"
                                  IsChecked="{Binding AutoAcceptUntrustedCertificates, Mode=TwoWay}"/>

                        <TextBlock Text="Session Timeout (ms):" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Height="35" Padding="10" 
                                 Text="{Binding SessionTimeout, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 Background="#ECEFF1" BorderBrush="#BDC3C7" BorderThickness="1"/>

                        <Button Content="Verbindung Prüfen" Height="40" Margin="0,15,0,0" 
                                Background="#27AE60" Foreground="White" FontWeight="SemiBold" FontSize="12"
                                Command="{Binding ConnectCommand}"
                                IsEnabled="{Binding IsConnecting, Converter={StaticResource InvertedBoolConverter}, Mode=OneWay}"/>
                    </StackPanel>
                </Border>

                <!-- Results Section -->
                <TextBlock Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" Text="Sicherheitsergebnisse:" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <Border Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2"
                        Margin="0,30,0,0" Background="White" BorderBrush="#D0D0D0" BorderThickness="1">
                    <StackPanel Margin="15">
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#7F8C8D" Margin="0,0,0,15"/>

                        <!-- Connection Status -->
                        <Border Background="#ECF0F1" BorderBrush="#BDC3C7" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="1. Verbindungsstatus" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding ConnectionStatus}" Foreground="#7F8C8D"/>
                            </StackPanel>
                        </Border>

                        <!-- Message Security Mode -->
                        <Border Background="#ECF0F1" BorderBrush="#BDC3C7" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="2. Message Security Mode" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding SecurityMode}" Foreground="#7F8C8D"/>
                            </StackPanel>
                        </Border>

                        <!-- Security Policy -->
                        <Border Background="#ECF0F1" BorderBrush="#BDC3C7" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="3. Security Policy" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding SecurityPolicy}" Foreground="#7F8C8D"/>
                            </StackPanel>
                        </Border>

                        <!-- Auto Accept Certificates -->
                        <Border Background="#ECF0F1" BorderBrush="#BDC3C7" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="4. Auto Accept Untrusted Certificates" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding AutoAcceptStatus}" Foreground="#7F8C8D"/>
                            </StackPanel>
                        </Border>

                        <!-- Server Certificate -->
                        <Border Background="#ECF0F1" BorderBrush="#BDC3C7" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="5. Server-Zertifikat" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding CertificateSubject}" Foreground="#7F8C8D"/>
                                <TextBlock Text="{Binding CertificateIssuer}" Foreground="#7F8C8D" Margin="0,3,0,0"/>
                                <TextBlock Text="{Binding CertificateDate}" Foreground="#7F8C8D" Margin="0,3,0,0"/>
                                <TextBlock Text="{Binding CertificateStatus}" Foreground="#7F8C8D" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Session Information -->
                        <Border Background="#ECF0F1" BorderBrush="#BDC3C7" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="6. Sitzungsinformationen" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding SessionId}" Foreground="#7F8C8D"/>
                                <TextBlock Text="{Binding SessionTimeoutDisplay}" Foreground="#7F8C8D" Margin="0,3,0,0"/>
                                <TextBlock Text="{Binding SessionConnected}" Foreground="#7F8C8D" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Error Log -->
                        <TextBlock Text="Detailliertes Fehlerlog:" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,10,0,5"/>
                        <ListBox Height="150" Background="#ECF0F1" BorderBrush="#BDC3C7" BorderThickness="1"
                                 Padding="10" ItemsSource="{Binding ErrorLogs, Mode=OneWay}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding .}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="10"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="2" Background="#34495E" Margin="0">
            <StackPanel Orientation="Horizontal" Margin="20">
                <TextBlock Text="© 2026 Security Check GUI" Foreground="#BDC3C7"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
